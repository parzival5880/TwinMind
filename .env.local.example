NEXT_PUBLIC_APP_NAME=TwinMind
STRICT_GROUNDING=0

# Azure OpenAI — used when these are set. Leave blank to fall back to Groq.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-oss-120b

# Groq — required for Whisper, 8B helpers, and large-model fallback.
NEXT_PUBLIC_GROQ_API_KEY=
